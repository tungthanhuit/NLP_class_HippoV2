# Copy to .env and fill in values.

# Required: upstream API key used by litellm_gateway/config.yaml
FPT_API_KEY=""

# Optional: protect the local gateway with a master key.
# If set, also uncomment general_settings.master_key in config.yaml.
LITELLM_MASTER_KEY=""

# Optional: override host/port (defaults are 0.0.0.0:4000)
# LITELLM_HOST=127.0.0.1
# LITELLM_PORT=4000
