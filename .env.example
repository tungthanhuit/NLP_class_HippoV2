# Copy this file to `.env` and fill in values.
# IMPORTANT: Never commit your real `.env` with secrets.

# --- OpenAI / OpenAI-compatible API ---
# If you use a local OpenAI-compatible gateway (e.g., LiteLLM), you may not need a real key,
# but some clients still require it to be set.
OPENAI_API_KEY=sk-key

# --- Neo4j (KB backend) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Soft-isolation for multiple KBs inside one Neo4j DB
NEO4J_NAMESPACE=hipporag

# --- Milvus / Zilliz (optional chunk vector backend) ---
# Used when chunk_vector_backend="milvus"
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=

# --- Convenience overrides used by tests/scripts ---
HIPPORAG_LLM_NAME=gpt-4o-mini
HIPPORAG_LLM_BASE_URL=http://localhost:4000/v1
HIPPORAG_EMBEDDING_MODEL_NAME=text-embedding-3-small
HIPPORAG_EMBEDDING_BASE_URL=http://localhost:4000/v1
HIPPORAG_CHUNK_VECTOR_BACKEND=default

# --- Dotenv control (optional) ---
# Set to 1/true/yes to disable auto-loading .env
HIPPORAG_DISABLE_DOTENV=0

# If set, loads this file instead of searching for a `.env` in CWD/parents
HIPPORAG_DOTENV_PATH=
